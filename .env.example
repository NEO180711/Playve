# 배포 도메인 (끝에 / 없이). OG·canonical·JSON-LD·빌드 시 sitemap.xml에 사용됩니다.
# VITE_SITE_URL=https://www.example.com

# 문의 페이지에 표시할 운영 이메일
# VITE_CONTACT_EMAIL=hello@example.com

# 디스플레이 광고 게시자 ID (index.html 기본값과 맞추려면 동일하게). 비우면 코드 기본값(ca-pub-9076263469821087) 사용.
# VITE_AD_CLIENT=ca-pub-9076263469821087

# (선택) 광고 단위 슬롯 ID(숫자)
# VITE_AD_SLOT_MAIN=
# VITE_AD_SLOT_FOOTER=
